[versions]
kotlin = "{{ kotlin_version }}"
{%- if kotest_convention %}
kotest = "{{ kotest_version }}"
{%- endif %}

[plugins]
kotlin-jvm = { id = "org.jetbrains.kotlin.jvm", version.ref = "kotlin" }

[libraries]
{%- if use_buildsrc %}
# Used by buildSrc so convention plugins can apply the Kotlin Gradle plugin.
kotlin-gradle-plugin = { module = "org.jetbrains.kotlin:kotlin-gradle-plugin", version.ref = "kotlin" }
{%- endif %}
{%- if kotest_convention %}
kotest-runner-junit5 = { module = "io.kotest:kotest-runner-junit5", version.ref = "kotest" }
kotest-assertions-core = { module = "io.kotest:kotest-assertions-core", version.ref = "kotest" }
{%- endif %}
{%- if not use_buildsrc %}
# Declare your dependencies here, e.g.:
# kotlinx-coroutines-core = { module = "org.jetbrains.kotlinx:kotlinx-coroutines-core", version = "1.10.2" }
{%- endif %}
